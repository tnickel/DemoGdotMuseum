[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://startup.gd" id="1_startup"]

[node name="StartupMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_startup")

[node name="ColorRect" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.08, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -100.0
offset_right = 200.0
offset_bottom = 100.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 20

[node name="Label" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Virtual Art Museum"
horizontal_alignment = 1

[node name="ButtonDesktop" type="Button" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 50)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Play 2D Desktop (Mouse & Keyboard)"

[node name="Desc2D" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)
text = "Lädt das Museum im Fenstermodus für den Monitor. VR System wird ignoriert."
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="VRInstructions" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.9, 0.4, 0.4, 1)
text = "VORBEREITUNG FÜR PSVR2:
1. PSVR2 Brille anschalten.
2. SteamVR starten (PlayStation VR2 App läuft automatisch im Hintergrund mit).
3. Sicherstellen, dass SteamVR die Brille und Controller erkennt.
4. Erst danach hier auf 'Play 3D VR' klicken!"
horizontal_alignment = 1

[node name="ButtonVR" type="Button" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 50)
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Play 3D VR (PSVR2 / SteamVR)"

[node name="DescVR" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.6, 0.8, 1.0, 1)
text = "Verbindet Godot mit SteamVR. Startet das Museum in Stereoskopischem 3D.
Bewegung & Steuerung direkt über die VR-Controller oder Tastatur möglich!"
horizontal_alignment = 1

[connection signal="pressed" from="VBoxContainer/ButtonDesktop" to="." method="_on_btn_2d_pressed"]
[connection signal="pressed" from="VBoxContainer/ButtonVR" to="." method="_on_btn_vr_pressed"]
